{
  "target": "linux/amd64",
  "http": "0.0.0.0:50004",
  "workdir": "/work/syzkaller/workdir-iter-cluster-unix_strea-h0",
  "kernel_obj": "/work/linux/build-latest",
  "kernel_src": "/work/linux/source",
  "image": "/work/initramfs/build/syzimg.img",
  "sshkey": "/work/initramfs/build/syzimg.id_rsa",
  "syzkaller": "/opt/syzkaller",
  "procs": 4,
  "type": "qemu",
  "vm": {
    "count": 4,
    "kernel": "/work/artifacts/bzImage-latest",
    "cpu": 2,
    "mem": 2048,
    "cmdline": "net.ifnames=0",
    "network_device": "virtio-net-pci",
    "qemu_args": "-enable-kvm -cpu host"
  },
  "reproduce": true,
  "cover": true,
  "sandbox": "setuid",
  "enable_syscalls": [
    "add_key",
    "close",
    "connect",
    "dup",
    "dup2",
    "dup3",
    "getxattr",
    "ioctl$PERF_EVENT_IOC_DISABLE",
    "ioctl$PERF_EVENT_IOC_ENABLE",
    "ioctl$PERF_EVENT_IOC_ID",
    "ioctl$PERF_EVENT_IOC_MODIFY_ATTRIBUTES",
    "ioctl$PERF_EVENT_IOC_PAUSE_OUTPUT",
    "ioctl$PERF_EVENT_IOC_PERIOD",
    "ioctl$PERF_EVENT_IOC_QUERY_BPF",
    "ioctl$PERF_EVENT_IOC_REFRESH",
    "ioctl$PERF_EVENT_IOC_RESET",
    "ioctl$PERF_EVENT_IOC_SET_BPF",
    "ioctl$PERF_EVENT_IOC_SET_FILTER",
    "ioctl$PERF_EVENT_IOC_SET_OUTPUT",
    "keyctl",
    "madvise",
    "mmap",
    "mremap",
    "msgget",
    "msgrcv",
    "msgsnd",
    "munmap",
    "perf_event_open",
    "perf_event_open$cgroup",
    "ppoll",
    "read",
    "recvmsg$unix",
    "sendmsg$netlink",
    "sendmsg$unix",
    "setxattr",
    "shutdown",
    "socketpair",
    "socketpair$unix",
    "write$binfmt_misc"
  ],
  "disable_syscalls": [
    "syz_io_uring_*",
    "io_uring_*"
  ]
}