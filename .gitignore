__pycache__/
*.pyc
run-logs/iter-*.jsonl
run-logs/llm-gateway.jsonl
run-logs/llm-gateway-*.log
# Per-phase scratch workdirs (synthesized harnesses, klee-out, cbmc PoVs).
# Keep the verdict summary JSONs at run-logs/phase*-*.json; drop intermediates.
run-logs/phase*/
run-logs/**/klee-out/

# CyberGym workspace
# (Note: .gitignore does NOT support trailing inline comments — each pattern
#  is the entire rest of the line, including the comment. Keep comments on
#  their own lines.)
# repo/ is a depth-1 upstream clone; re-fetch with:
#   git clone --depth 1 https://github.com/sunblaze-ucb/cybergym.git eval/cybergym/repo
eval/cybergym/repo/
# python3.12 venv with cybergym[dev,server] (~270 MB)
eval/cybergym/venv/
# gen_task scratch (regenerated each run)
eval/cybergym/tmp_task/
# runtime SQLite DB + per-PoC logs
eval/cybergym/server_state/
# Per-task HuggingFace data (PoCs, repo tarballs); fetched on demand.
eval/cybergym/data/

# Proof cache contents are runtime state (rebuilt on demand). Keep dir, drop rows.
surface/proofcache/*/

# Juliet C/C++ v1.3 corpus (NIST SARD, 153 MB zip / 652 MB extracted). Re-fetch:
#   curl -L -o eval/juliet/raw/juliet-c-cpp-v1.3.zip \
#     https://samate.nist.gov/SARD/downloads/test-suites/2017-10-01-juliet-test-suite-for-c-cplusplus-v1-3.zip
#   unzip eval/juliet/raw/juliet-c-cpp-v1.3.zip -d eval/juliet/extracted/
eval/juliet/raw/
eval/juliet/extracted/

# kernelCTF heavy artifacts (sources + initramfs + bzImage rebuilt on demand)
eval/kernelctf/linux/
eval/kernelctf/rootfs/
eval/kernelctf/artifacts/bzImage
eval/kernelctf/artifacts/initramfs.cpio.gz
eval/kernelctf/artifacts/bzImage-live
eval/kernelctf/artifacts/initramfs-live.cpio.gz
eval/kernelctf/artifacts/build-live-stderr.log
eval/kernelctf/artifacts/build-live-stdout.log

# kernelCTF-latest heavy artifacts (sources + bzImage + initramfs rebuilt
# from pinned recipe in eval/kernelctf-latest/scripts/).
eval/kernelctf-latest/linux/
eval/kernelctf-latest/initramfs/
eval/kernelctf-latest/artifacts/bzImage-latest
eval/kernelctf-latest/artifacts/initramfs-latest.cpio.gz
eval/kernelctf-latest/artifacts/build-latest-stderr.log
eval/kernelctf-latest/artifacts/build-latest-stdout.log
eval/kernelctf-latest/artifacts/dmesg-latest-setup.log
# lakitu_defconfig is re-fetched from cos.googlesource.com by make_config_latest.sh
eval/kernelctf-latest/configs/lakitu_defconfig
eval/kernelctf-latest/configs/lakitu_defconfig.b64
# syz-manager workdirs (corpus + crashes — runtime state)
eval/kernelctf-latest/syzkaller/workdir-*/

# libFuzzer / MSan / profile-runtime artifacts (drop in cwd during runs)
%%stderr
*.profraw
generate_temporary_file.*.mgc
http_config.conf
random.icc
fuzz-*-config-read-*

# Transient leaderboard smoke artifacts (kept only the full-1507 runs)
run-logs/leaderboard-regression*.json*
run-logs/leaderboard-regression*.jsonl
run-logs/leaderboard-server-smoke*.jsonl
run-logs/leaderboard-server-smoke*.json
run-logs/leaderboard-multiturn-subset*.jsonl
run-logs/leaderboard-multiturn-subset*.json
run-logs/leaderboard-bankfuzz-smoke*.json*
run-logs/leaderboard-bankonly-smoke*.json*
run-logs/leaderboard-smoke*.json*
run-logs/llm-gateway.log

# Pre-commit hook private state
scripts/git-hooks/targets.txt

# Fine-tuned LoRA adapters (large binaries, regenerable via tools/train_seedgen.py)
run-logs/seedgen/*-lora/
*.safetensors
# Per-task L1 eval traces (keep summary JSONs, drop the large trace JSONL)
run-logs/l1-*-trace.jsonl

# CodeQL CLI+query-pack bundle (in-workspace, ~2.5GB) + built kernel DBs — regenerable
tools/codeql/
run-logs/codeql-db/
