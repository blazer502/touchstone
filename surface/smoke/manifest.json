{
  "target": "stage_b-smoke",
  "build_flags": {
    "sanitizer": "none",
    "arch": "x86_64",
    "machdep": "x86_64"
  },
  "units": [
    {
      "source": "safe_clamp.c",
      "function": "main",
      "property": "memory-safety",
      "engines": ["cbmc"],
      "unwind": 4,
      "expected": "safe",
      "assumed_contracts": ["caller bounds i < N before clamp_write call"]
    },
    {
      "source": "unsafe_oob.c",
      "function": "main",
      "property": "no-oob",
      "engines": ["cbmc"],
      "unwind": 4,
      "expected": "unsafe",
      "assumed_contracts": []
    },
    {
      "source": "unbounded_loop.c",
      "function": "main",
      "property": "no-overflow",
      "engines": ["cbmc"],
      "unwind": 4,
      "expected": "inconclusive",
      "assumed_contracts": []
    },
    {
      "source": "contracted_copy.c",
      "function": "main",
      "property": "memory-safety",
      "engines": ["cbmc"],
      "unwind": 36,
      "expected": "safe",
      "assumed_contracts": ["__CPROVER_assume(len <= CAP)"]
    }
  ]
}
